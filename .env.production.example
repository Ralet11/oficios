# ==========================================
# PRODUCTION ENVIRONMENT - OFICIOS API
# ==========================================

# App
NODE_ENV=production
PORT=4000
APP_URL=https://tu-dominio.com
CORS_ORIGIN=https://tu-dominio.com

# Database (External PostgreSQL on Docker/EC2)
DATABASE_URL=postgres://usuario:password@host:5432/oficios_prod

# JWT
JWT_SECRET=cambia-esto-por-un-secreto-super-largo-y-seguro

# Upload Provider (cloudinary or s3)
UPLOAD_PROVIDER=cloudinary
UPLOAD_MAX_FILE_SIZE_MB=12

# Cloudinary (if using Cloudinary)
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
CLOUDINARY_UPLOAD_FOLDER=oficios

# S3 (if using S3 instead)
# S3_BUCKET=your-public-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key-id
# S3_SECRET_ACCESS_KEY=your-secret-access-key
# S3_PUBLIC_BASE_URL=https://your-public-bucket.s3.us-east-1.amazonaws.com
# S3_UPLOAD_PREFIX=oficios

# Business Logic
SELECTION_TIMEOUT_HOURS=24
