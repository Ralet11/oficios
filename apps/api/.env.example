NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/oficios
JWT_SECRET=replace-with-a-long-secret
APP_URL=http://localhost:8081
CORS_ORIGIN=http://localhost:8081

UPLOAD_PROVIDER=cloudinary
UPLOAD_MAX_FILE_SIZE_MB=12

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_UPLOAD_FOLDER=oficios

S3_BUCKET=your-public-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_PUBLIC_BASE_URL=https://your-public-bucket.s3.us-east-1.amazonaws.com
S3_UPLOAD_PREFIX=oficios
